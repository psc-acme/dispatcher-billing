{
    "name": "psc-acme/dispatcher-billing",
    "description": "Package dispatcher-billing for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\DispatcherBilling\\": "src/"
        }
    },
    "require": {
        "php": ">=8.1",
        "symfony/lock": "^7.0",
        "predis/predis": "^2.0",
        "symfony/uid": "^7.0",
        "symfony/routing": "^7.0",
        "ramsey/uuid": "^4.0"
    },
    "require-dev": {
        "rector/rector": "^1.0"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}